# ==================== 运行模式总开关 ====================
# OCR 提供方：paddle / openai
OCR_PROVIDER="paddle"

# Embedding 提供方：ollama / openai
EMBEDDING_PROVIDER="ollama"


# ==================== 通用超时与批量参数 ====================
# OCR 请求超时时间（秒）
OCR_TIMEOUT_SECONDS=60

# Embedding 请求超时时间（秒）
EMBEDDING_TIMEOUT_SECONDS=60

# Embedding 批处理大小，仅对批量向量化生效
EMBEDDING_BATCH_SIZE=32


# ==================== PostgreSQL 元数据存储 ====================
# PostgreSQL 主机地址
POSTGRES_HOST="localhost"

# PostgreSQL 端口
POSTGRES_PORT=5432

# 数据库名
POSTGRES_DB="postgres"

# 用户名
POSTGRES_USER="postgres"

# 密码；本地无密码可留空
POSTGRES_PASSWORD=""

# 使用的 schema；默认 public
POSTGRES_SCHEMA="public"

# SSL 模式；本地开发通常用 prefer
POSTGRES_SSLMODE="prefer"

# 连接超时时间（秒）
POSTGRES_TIMEOUT_SECONDS=30


# ==================== Milvus 向量检索 ====================
# Milvus 服务地址
MILVUS_URI="http://localhost:19530"

# Milvus 鉴权 token；未启用鉴权可留空
MILVUS_TOKEN=""

# Milvus 数据库名；未使用多库可留空
MILVUS_DB_NAME=""

# Milvus 请求超时时间（秒）
MILVUS_TIMEOUT_SECONDS=30

# 混合检索融合策略：weighted / rrf
MILVUS_RANKER_STRATEGY="weighted"

# weighted 策略下的 dense 权重
MILVUS_DENSE_WEIGHT=0.7

# weighted 策略下的 sparse 权重
MILVUS_SPARSE_WEIGHT=0.3

# rrf 策略下的 K 参数
MILVUS_RRF_K=60

# 是否额外收集 dense / sparse 分项分数
MILVUS_COLLECT_SCORE_BREAKDOWN=false

# 稀疏倒排索引算法：DAAT_MAXSCORE / DAAT_WAND / TAAT_NAIVE
MILVUS_SPARSE_INVERTED_INDEX_ALGO="DAAT_MAXSCORE"


# ==================== Reranker 语义重排 ====================
# Cross-encoder 模型名
RERANKER_MODEL_NAME="BAAI/bge-reranker-v2-m3"

# 重排批大小
RERANKER_BATCH_SIZE=16

# 单次重排允许的最大 token 长度
RERANKER_MAX_LENGTH=1024

# 推理设备；留空表示交给底层框架自动选择
RERANKER_DEVICE=""


# ==================== Paddle OCR 配置 ====================
# 仅当 OCR_PROVIDER=paddle 时生效
PADDLE_OCR_API_KEY=""
PADDLE_OCR_BASE_URL=""


# ==================== OpenAI OCR 配置 ====================
# 仅当 OCR_PROVIDER=openai 时生效
OPENAI_API_KEY=""

# OpenAI API Base；走官方接口时通常无需改动
OPENAI_API_BASE="https://api.openai.com/v1"

# OpenAI 视觉 OCR 模型名
OPENAI_API_MODEL=""


# ==================== OpenAI Embedding 配置 ====================
# 仅当 EMBEDDING_PROVIDER=openai 时生效
EMBEDDING_OPENAI_API_KEY=""
EMBEDDING_OPENAI_API_BASE="https://api.openai.com/v1"
EMBEDDING_OPENAI_MODEL="text-embedding-3-large"


# ==================== Ollama Embedding 配置 ====================
# 仅当 EMBEDDING_PROVIDER=ollama 时生效
EMBEDDING_OLLAMA_BASE_URL="http://localhost:11434"
EMBEDDING_OLLAMA_MODEL="qwen3-embedding"
